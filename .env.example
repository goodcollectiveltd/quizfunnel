# Copy to .env for local dev, and set these in your host (Vercel/Netlify) for production.
# ALL are optional — with none set, tracking/email are safe no-ops and the quiz still works.
# Vite only exposes vars prefixed with VITE_. Rebuild after changing them.

# Meta (Facebook) Pixel — enables PageView + quiz_start / quiz_completed / Lead /
# InitiateCheckout / CompleteRegistration events, and forwards fbclid/_fbp/_fbc to Shopify.
VITE_META_PIXEL_ID=

# GA4 Measurement ID (G-XXXXXXXXXX) — mirrors the same events to Google Analytics.
VITE_GA4_ID=

# Klaviyo email capture (the optional "email me the plan" field on the result page).
# Public API key = your Klaviyo "company id" (6 chars). List id = the list to add finishers to.
VITE_KLAVIYO_PUBLIC_KEY=
VITE_KLAVIYO_LIST_ID=
